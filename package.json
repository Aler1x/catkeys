{
  "name": "catkeys",
  "description": "Zen-style keyboard shortcuts: copy tab URL and duplicate tab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.5",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "generate:screenshots": "tsx scripts/generate-screenshots.ts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "satori": "^0.18.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "wxt": "^0.20.26"
  }
}
